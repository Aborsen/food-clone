{
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.3.0"
    }
  },
  "crons": [
    {
      "path": "/api/cron_daily_summary",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron_midnight_reset",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron_cardio_reminder",
      "schedule": "30 4 * * 1-6"
    }
  ]
}
